// Firestore Security Rules para Task Manager v3.3+
//
// COMO APLICAR:
// 1) Firebase Console → https://console.firebase.google.com/project/app-de-tareas-e4209/firestore/rules
// 2) Pegar este contenido entero (reemplazando lo que esté)
// 3) Click "Publicar"
//
// Si no las aplicás, el flujo de invitaciones / aprobación NO va a funcionar:
// los nuevos usuarios no podrán crear su propio doc en /users, y los admins
// no podrán crear códigos en /inviteCodes.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===== users =====
    // Read: cualquier autenticado (necesario para asignar tareas, chat, etc).
    // Create: solo el dueño puede crear su propio doc al registrarse.
    // Update: el dueño puede editar campos propios; los admins pueden editar
    // role/status/activatedAt/rejectedAt para aprobar/rechazar/promover.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ===== inviteCodes =====
    // get: cualquier autenticado puede leer un codigo individual para validarlo
    //      al registrarse. NO permite list — solo lecturas por ID.
    // list: solo admin (para mostrar el listado en el panel).
    // create/delete: solo admin.
    // update: admin (revocar) o el usuario que lo esta canjeando (marcarlo usado).
    match /inviteCodes/{code} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (isSignedIn() && request.resource.data.usedBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ===== workspaces (v3.8.0) =====
    // Lectura: cualquier autenticado puede leer (necesario para que los miembros vean
    // la lista y elijan workspace). El listener filtra client-side por miembros.
    // Crear: cualquier autenticado puede crear (será el owner).
    // Update: el owner del workspace o un admin global puede modificarlo.
    // Delete: solo admin global.
    match /workspaces/{workspaceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );
    }

    // ===== recordingSessions (v3.10.0) =====
    // Sesiones efímeras (~1h) para que el celular grabe video y lo suba al entry.
    // El celular abre /recorder/?session=XXX SIN auth Firebase, así que necesitamos
    // permitir lectura pública por ID (NO list — solo gets).
    // Update también es público porque el celular escribe el videoUrl al final, pero
    // restringimos los campos que puede tocar para que no manipule entryId/cloudName/etc.
    // Create/delete: solo usuarios autenticados (desktop).
    match /recordingSessions/{sessionId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        || (
          // Mobile recorder anonymous update — solo puede tocar campos de progreso/resultado
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'videoUrl', 'videoBytes', 'videoFormat', 'videoDuration', 'videoWidth', 'videoHeight', 'completedAt'])
        );
      allow delete: if isSignedIn();
    }

    // ===== Resto de colecciones del producto =====
    // Cualquier autenticado puede leer/escribir. Mismo comportamiento que tenia
    // antes — la unica diferencia es que ahora estan listadas explicitamente
    // en vez de por wildcard, para que el wildcard NO opaque las reglas
    // restrictivas de /users e /inviteCodes (las rules de Firestore son
    // aditivas: si CUALQUIER match permite, se permite).
    match /tasks/{id}                      { allow read, write: if isSignedIn(); }
    match /projects/{id}                   { allow read, write: if isSignedIn(); }
    match /depositEntries/{id}             { allow read, write: if isSignedIn(); }
    match /depositCategories/{id}          { allow read, write: if isSignedIn(); }
    match /scheduledPosts/{id}             { allow read, write: if isSignedIn(); }
    match /chatMessages/{id}               { allow read, write: if isSignedIn(); }
    match /directMessages/{id}             { allow read, write: if isSignedIn(); }
    match /captionTemplates/{id}           { allow read, write: if isSignedIn(); }
    match /sceneInstructionTemplates/{id}  { allow read, write: if isSignedIn(); }
    match /personalTasks/{id}              { allow read, write: if isSignedIn(); }
    match /ideas/{id}                      { allow read, write: if isSignedIn(); }
    match /notifications/{id}              { allow read, write: if isSignedIn(); }
    match /config/{id}                     { allow read, write: if isSignedIn(); }
    // v3.11.80 + v3.11.89: Bot IA — colecciones del chatbot.
    // Para que el CF Pages Function (/manychat/inbound) pueda escribir leads y
    // mensajes sin auth, permitimos create público en chatbotLeads/Messages,
    // y read público en chatbotBusinesses/Config (para que el webhook lea
    // system prompt + KB). Las apps autenticadas tienen control total.
    match /chatbotBusinesses/{id} {
      allow read: if true;          // CF function lee nombre del negocio
      allow write: if isSignedIn();
    }
    match /chatbotLeads/{id} {
      allow read: if isSignedIn();
      allow create: if true;        // CF function crea lead nuevo en DM
      allow update: if isSignedIn() || (
        // CF function actualiza solo lastMessageAt/Preview/contactId
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['lastMessageAt', 'lastMessagePreview', 'manychatContactId'])
      );
      allow delete: if isSignedIn();
    }
    match /chatbotMessages/{id} {
      allow read: if isSignedIn();
      allow create: if true;        // CF function escribe user msg + bot msg
      allow update, delete: if isSignedIn();
    }
    match /chatbotConfig/{id} {
      allow read: if true;          // CF function lee system prompt + KB
      allow write: if isSignedIn();
    }
    match /chatbotKnowledgeBase/{id}       { allow read, write: if isSignedIn(); }
    match /chatbotAppointments/{id} {
      allow read: if isSignedIn();
      allow create: if true;          // CF function GHL webhook escribe citas agendadas
      allow update, delete: if isSignedIn();
    }
    // v3.11.82: webhookInbox — Cloudflare Worker escribe acá (sin auth) DMs nuevos de IG.
    // Permitimos create público pero solo signed-in users pueden leer/borrar (procesar).
    match /webhookInbox/{id} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }
  }
}
