{
  "name": "task-manager-app",
  "version": "2.67.0",
  "description": "App colaborativa de gestion de tareas con Firebase y Telegram",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder --mac --win",
    "publish:mac": "electron-builder --mac --publish always",
    "publish:win": "electron-builder --win --publish always",
    "publish": "electron-builder --mac --win --publish always"
  },
  "build": {
    "appId": "com.jainier.taskmanager",
    "productName": "Task Manager",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "deposit.html",
      "deposit-preload.js",
      "deposit-renderer.js",
      "chat.html",
      "chat-preload.js",
      "chat-renderer.js",
      "vendor/**/*",
      "icon.png"
    ],
    "publish": {
      "provider": "github",
      "owner": "jainierrojas-arch",
      "repo": "task-manager-app",
      "releaseType": "release"
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "shortcutName": "Task Manager"
    },
    "dmg": {
      "title": "Task Manager",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "electron-updater": "^6.8.3",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
